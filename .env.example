# Resend — envío de emails desde el formulario de contacto
# Obtener en: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Sanity CMS — blog y portfolio
# Obtener en: sanity.io → tu proyecto → Settings → API
SANITY_PROJECT_ID=xxxxxxxxxx
SANITY_DATASET=production
SANITY_API_TOKEN=sk_xxxxxxxxxxxx

# URL pública del sitio (sin trailing slash)
PUBLIC_SITE_URL=https://avefenixsoftware.com

# Email destino del formulario de contacto
CONTACT_EMAIL=daferur@gmail.com

# URL de la Firebase Function de contacto (se obtiene tras el primer deploy)
# Formato: https://europe-west1-TU_PROJECT_ID.cloudfunctions.net/contact
PUBLIC_CONTACT_FUNCTION_URL=https://europe-west1-TU_PROJECT_ID.cloudfunctions.net/contact
