---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Button from '@/components/ui/Button.astro';
import CTA from '@/components/sections/CTA.astro';

const servicios = [
  {
    id: 'web',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="3" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>`,
    title:       'Desarrollo Web',
    tagline:     'Webs que convierten visitas en clientes',
    description: 'Diseñamos y desarrollamos páginas web y tiendas online de alto rendimiento. Cada proyecto es único, pensado para tus objetivos y tu audiencia. Nada de plantillas — todo a medida.',
    bullets: [
      'Landing pages de alto impacto con diseño premium',
      'Tiendas online y e-commerce (Shopify, WooCommerce, custom)',
      'Webs corporativas y páginas de empresa',
      'Blogs y portales de contenido',
      'Optimizadas para Google (SEO técnico incluido)',
      'Velocidad de carga máxima — Lighthouse 95+',
    ],
    highlight: 'La web de tu empresa es tu mejor comercial. Trabaja las 24 horas, los 365 días del año.',
  },
  {
    id: 'software',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title:       'Software a Medida',
    tagline:     'Tu herramienta, construida para tu problema exacto',
    description: 'Desarrollamos aplicaciones web y sistemas personalizados que resuelven exactamente el problema de tu negocio. Sin compromisos, sin funciones que no necesitas.',
    bullets: [
      'CRMs personalizados adaptados a tu proceso de ventas',
      'ERPs y sistemas de gestión interna',
      'Plataformas SaaS y productos digitales',
      'APIs y microservicios para integrar tus sistemas',
      'Paneles de administración y dashboards',
      'Aplicaciones web progresivas (PWA)',
    ],
    highlight: 'Si algo te cuesta tiempo o dinero por hacerlo manualmente, existe una solución de software para ello.',
  },
  {
    id: 'automatizacion',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
    title:       'Automatizaciones',
    tagline:     'Trabaja menos. Produce más.',
    description: 'Identificamos las tareas repetitivas que consumen el tiempo de tu equipo y las automatizamos. Conectamos tus herramientas y creamos flujos inteligentes.',
    bullets: [
      'Automatizaciones con n8n, Make y Zapier',
      'Integraciones entre CRM, ERP y herramientas externas',
      'Bots y asistentes con inteligencia artificial',
      'Generación automática de reportes y facturas',
      'Notificaciones y alertas automáticas',
      'Sincronización de datos entre plataformas',
    ],
    highlight: 'Nuestros clientes recuperan entre 10 y 30 horas semanales con automatizaciones bien implementadas.',
  },
  {
    id: 'seo',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>`,
    title:       'Auditoría SEO',
    tagline:     'Sube posiciones. Gana más clientes orgánicos.',
    description: 'Analizamos tu presencia digital con herramientas profesionales y te decimos exactamente qué hacer para posicionarte mejor que tu competencia en Google.',
    bullets: [
      'Auditoría técnica completa de tu web',
      'Análisis de palabras clave y oportunidades',
      'Análisis de competencia y estrategia para superarles',
      'Plan de contenidos para atraer tráfico cualificado',
      'Optimización on-page y off-page',
      'Seguimiento mensual de posiciones y métricas',
    ],
    highlight: 'El SEO bien hecho es la inversión de marketing con mejor ROI a largo plazo.',
  },
];
---

<BaseLayout
  title="Servicios"
  description="Desarrollo web, software a medida, automatizaciones empresariales y auditoría SEO. Soluciones tecnológicas para empresas que quieren crecer."
>
  <!-- Hero de página -->
  <section class="page-hero">
    <div class="section-container">
      <p class="page-eyebrow">Lo que hacemos</p>
      <h1 class="page-title gradient-text">SERVICIOS</h1>
      <p class="page-subtitle">
        Todo lo que tu empresa necesita para crecer en digital.<br/>
        Sin intermediarios. Sin sorpresas. Con resultados medibles.
      </p>
    </div>
  </section>

  <!-- Servicios detallados -->
  <section class="services-detail">
    <div class="section-container">
      {servicios.map((s, i) => (
        <div class="service-item" id={s.id}>
          <div class={`service-row ${i % 2 === 1 ? 'service-row--reverse' : ''}`}>
            <div class="service-content">
              <div class="service-icon" aria-hidden="true" set:html={s.icon} />
              <h2 class="service-name">{s.title}</h2>
              <p class="service-tagline">{s.tagline}</p>
              <p class="service-desc">{s.description}</p>
              <ul class="service-list" aria-label={`Qué incluye ${s.title}`}>
                {s.bullets.map((b) => (
                  <li>
                    <span class="bullet-icon" aria-hidden="true">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </span>
                    {b}
                  </li>
                ))}
              </ul>
              <Button href="/contacto" size="lg">Pedir presupuesto</Button>
            </div>
            <div class="service-highlight-box">
              <p class="highlight-text">"{s.highlight}"</p>
            </div>
          </div>
          {i < servicios.length - 1 && <hr class="service-divider" />}
        </div>
      ))}
    </div>
  </section>

  <CTA />
</BaseLayout>

<style>
  .page-hero {
    padding: 10rem 0 5rem;
    background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(154, 52, 18, 0.2) 0%, transparent 60%);
    text-align: center;
  }

  .page-eyebrow {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--phoenix-fire);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }

  .page-title {
    font-size: clamp(3rem, 10vw, 7rem);
    margin-bottom: 1.5rem;
  }

  .page-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .services-detail { padding: 5rem 0; }

  .service-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .service-row { grid-template-columns: 1.5fr 1fr; }
    .service-row--reverse { direction: rtl; }
    .service-row--reverse > * { direction: ltr; }
  }

  .service-content { display: flex; flex-direction: column; gap: 1.25rem; }

  .service-icon {
    width: 56px; height: 56px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(234, 88, 12, 0.1);
    border: 1px solid rgba(234, 88, 12, 0.2);
    border-radius: var(--radius-md);
    color: var(--phoenix-fire);
  }

  .service-name {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--text-primary);
  }

  .service-tagline {
    font-family: var(--font-ui);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--phoenix-gold);
  }

  .service-desc { font-size: 1rem; color: var(--text-secondary); line-height: 1.7; }

  .service-list {
    list-style: none;
    display: flex; flex-direction: column; gap: 0.6rem;
  }

  .service-list li {
    display: flex; align-items: flex-start; gap: 0.75rem;
    font-family: var(--font-ui); font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .bullet-icon {
    display: flex; align-items: center; justify-content: center;
    width: 20px; height: 20px; flex-shrink: 0; margin-top: 1px;
    background: rgba(34, 197, 94, 0.1);
    border-radius: 50%;
    color: var(--success);
  }

  .service-highlight-box {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--phoenix-fire);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    display: flex; align-items: center;
  }

  .highlight-text {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    color: var(--text-primary);
    line-height: 1.3;
    letter-spacing: 0.02em;
  }

  .service-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 5rem 0;
  }
</style>
