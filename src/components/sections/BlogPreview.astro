---
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import { formatDate } from '@/lib/utils';
import type { Post } from '@/types/blog';

interface Props {
  posts?: Post[];
}

const { posts } = Astro.props;

// Placeholder hasta conectar Sanity
const placeholder = [
  {
    _id:         'p1',
    title:       '5 señales de que tu web necesita una renovación urgente',
    slug:        { current: '5-senales-web-renovacion' },
    excerpt:     'Si tu web tarda más de 3 segundos en cargar o no se ve bien en móvil, estás perdiendo clientes cada día. Te explicamos las señales clave.',
    category:    'Desarrollo' as const,
    publishedAt: '2026-05-15',
    readTime:    5,
  },
  {
    _id:         'p2',
    title:       'Cómo automatizamos el 80% de las tareas de una gestoría en 2 semanas',
    slug:        { current: 'automatizacion-gestoria-caso-real' },
    excerpt:     'Caso real: de 20 horas semanales de trabajo manual a 4. Te contamos qué hicimos y cómo puedes replicarlo en tu negocio.',
    category:    'Automatización' as const,
    publishedAt: '2026-04-28',
    readTime:    7,
  },
  {
    _id:         'p3',
    title:       'SEO para PYMEs: los 10 errores que comete el 90% de las empresas',
    slug:        { current: 'seo-pymes-10-errores' },
    excerpt:     'La mayoría de las PYMEs cometen los mismos errores de SEO. Aprende a evitarlos con esta guía práctica y gratuita.',
    category:    'SEO' as const,
    publishedAt: '2026-04-10',
    readTime:    8,
  },
];

const displayPosts = (posts?.length ? posts : placeholder) as typeof placeholder;
---

<section class="blog-preview" id="blog">
  <div class="section-container">
    <SectionHeader
      eyebrow="Conocimiento"
      title="BLOG"
      subtitle="Artículos prácticos sobre tecnología, SEO y automatización para empresas."
    />

    <div class="posts-grid">
      {displayPosts.map((post, i) => (
        <a href={`/blog/${post.slug.current}`} class="post-card reveal-post" style={`--delay: ${i * 0.15}s`}>
          <div class="post-meta">
            <Badge variant="fire">{post.category}</Badge>
            <span class="read-time">{post.readTime} min</span>
          </div>
          <h3 class="post-title">{post.title}</h3>
          <p class="post-excerpt">{post.excerpt}</p>
          <footer class="post-footer">
            <time datetime={post.publishedAt}>{formatDate(post.publishedAt)}</time>
            <span class="read-more" aria-hidden="true">Leer →</span>
          </footer>
        </a>
      ))}
    </div>

    <div class="blog-cta">
      <Button href="/blog" variant="ghost" size="lg">Ver todos los artículos →</Button>
    </div>
  </div>
</section>

<style>
  .blog-preview {
    padding: 7rem 0;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .posts-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
    opacity: 0;
    transform: translateY(20px);
    transition-delay: var(--delay, 0s);
    cursor: pointer;
  }

  .post-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .post-card:hover {
    border-color: var(--phoenix-ember);
    box-shadow: var(--shadow-glow-sm);
    transform: translateY(-3px);
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .read-time {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .post-title {
    font-family: var(--font-ui);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.4;
    flex: 1;
  }

  .post-excerpt {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    font-size: 0.8rem;
  }

  time {
    color: var(--text-muted);
    font-family: var(--font-ui);
  }

  .read-more {
    color: var(--phoenix-fire);
    font-family: var(--font-ui);
    font-weight: 600;
    font-size: 0.85rem;
    transition: color 0.2s ease;
  }

  .post-card:hover .read-more {
    color: var(--phoenix-gold);
  }

  .blog-cta {
    margin-top: 3rem;
    text-align: center;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          observer.unobserve(e.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.reveal-post').forEach((el) => observer.observe(el));
</script>
