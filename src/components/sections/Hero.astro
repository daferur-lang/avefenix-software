---
import Button from '@/components/ui/Button.astro';
import Badge from '@/components/ui/Badge.astro';

const services = ['Desarrollo Web', 'Software a medida', 'Automatizaciones', 'Auditoría SEO'];
---

<section class="hero" aria-label="Avefenix Software — bienvenida">
  <!-- Grain texture overlay -->
  <svg class="grain" aria-hidden="true">
    <filter id="noise">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/>
      <feColorMatrix type="saturate" values="0"/>
    </filter>
    <rect width="100%" height="100%" filter="url(#noise)" opacity="0.04"/>
  </svg>

  <!-- Ember particles decoration -->
  <div class="embers" aria-hidden="true">
    <span class="ember ember-1"></span>
    <span class="ember ember-2"></span>
    <span class="ember ember-3"></span>
    <span class="ember ember-4"></span>
    <span class="ember ember-5"></span>
  </div>

  <div class="hero-inner section-container">
    <!-- Eyebrow -->
    <div class="hero-eyebrow animate-reveal stagger-1">
      <span class="eyebrow-dot" aria-hidden="true"></span>
      <span>Agencia de tecnología</span>
    </div>

    <!-- Headline -->
    <h1 class="hero-title animate-reveal stagger-2">
      TRANSFORMAMOS<br/>
      <span class="gradient-text animate-gradient-text">TU NEGOCIO</span><br/>
      CON TECNOLOGÍA
    </h1>

    <!-- Tagline -->
    <p class="hero-tagline animate-reveal stagger-3">
      Construimos el software que lleva tu empresa al siguiente nivel.<br class="desktop-only"/>
      Desde webs que convierten hasta automatizaciones que liberan tu tiempo.
    </p>

    <!-- Service chips -->
    <div class="service-chips animate-reveal stagger-4" aria-label="Nuestros servicios">
      {services.map((s) => (
        <Badge variant="muted">{s}</Badge>
      ))}
    </div>

    <!-- CTAs -->
    <div class="hero-ctas animate-reveal stagger-5">
      <Button href="/portfolio" size="lg">Ver nuestro trabajo</Button>
      <Button href="/contacto" variant="ghost" size="lg">Contactar</Button>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator animate-reveal stagger-6" aria-hidden="true">
      <span class="scroll-line animate-scroll-bounce">
        <svg width="16" height="24" viewBox="0 0 16 24" fill="none">
          <rect x="1" y="1" width="14" height="22" rx="7" stroke="currentColor" stroke-width="1.5" stroke-opacity="0.4"/>
          <circle cx="8" cy="7" r="2" fill="currentColor" opacity="0.6"/>
        </svg>
      </span>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background:
      radial-gradient(ellipse 80% 60% at 50% -10%, rgba(154, 52, 18, 0.25) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 80% 50%, rgba(234, 88, 12, 0.08) 0%, transparent 50%),
      var(--bg-void);
    background-size: 200% 200%;
    animation: meshMove 12s ease-in-out infinite;
  }

  .grain {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* Ember floating particles */
  .embers { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }

  .ember {
    position: absolute;
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--phoenix-fire);
    opacity: 0;
    animation: emberFloat 6s ease-in-out infinite;
  }

  .ember-1 { left: 15%; bottom: 20%; animation-delay: 0s;    animation-duration: 7s; }
  .ember-2 { left: 35%; bottom: 30%; animation-delay: 1.5s;  animation-duration: 5s; width: 2px; height: 2px; background: var(--phoenix-gold); }
  .ember-3 { left: 60%; bottom: 15%; animation-delay: 3s;    animation-duration: 8s; }
  .ember-4 { left: 75%; bottom: 40%; animation-delay: 0.8s;  animation-duration: 6s; width: 2px; height: 2px; }
  .ember-5 { left: 90%; bottom: 25%; animation-delay: 2.2s;  animation-duration: 7s; background: var(--phoenix-bright); }

  @keyframes emberFloat {
    0%   { opacity: 0;    transform: translateY(0) scale(1); }
    20%  { opacity: 0.8; }
    100% { opacity: 0;    transform: translateY(-120px) scale(0.3); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-top: 8rem;
    padding-bottom: 6rem;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    opacity: 0;
  }

  .eyebrow-dot {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--phoenix-fire);
    animation: firePulse 2.5s ease-in-out infinite;
  }

  .hero-title {
    font-size: clamp(3rem, 10vw, 7.5rem);
    line-height: 0.95;
    color: var(--text-primary);
    opacity: 0;
  }

  .animate-gradient-text {
    background: var(--gradient-phoenix);
    background-size: 200% 200%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientShift 4s ease infinite;
  }

  .hero-tagline {
    max-width: 560px;
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    color: var(--text-secondary);
    line-height: 1.7;
    opacity: 0;
  }

  .service-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    opacity: 0;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    opacity: 0;
  }

  .scroll-indicator {
    margin-top: 2rem;
    opacity: 0;
    color: var(--text-muted);
  }

  /* Reveal animations */
  .animate-reveal {
    animation: revealUp 0.7s ease forwards;
  }

  .desktop-only { display: none; }
  @media (min-width: 768px) { .desktop-only { display: inline; } }
</style>
