---
interface Props {
  variant?: 'primary' | 'ghost' | 'outline';
  size?:    'sm' | 'md' | 'lg';
  href?:    string;
  type?:    'button' | 'submit' | 'reset';
  class?:   string;
  disabled?: boolean;
  'aria-label'?: string;
}

const {
  variant = 'primary',
  size    = 'md',
  href,
  type    = 'button',
  class:  extraClass = '',
  disabled,
  'aria-label': ariaLabel,
} = Astro.props;

const classes = ['btn', `btn--${variant}`, `btn--${size}`, extraClass].filter(Boolean).join(' ');
---

{href ? (
  <a href={href} class={classes} aria-label={ariaLabel}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} disabled={disabled} aria-label={ariaLabel}>
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-ui);
    font-weight: 600;
    text-decoration: none;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-sm);
    transition: opacity 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .btn:hover { transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }

  /* Sizes */
  .btn--sm { padding: 0.4rem 0.875rem; font-size: 0.8rem; }
  .btn--md { padding: 0.65rem 1.5rem;  font-size: 0.9rem; }
  .btn--lg { padding: 0.875rem 2rem;   font-size: 1rem; }

  /* Variants */
  .btn--primary {
    background: var(--gradient-phoenix);
    color: var(--bg-void);
  }
  .btn--primary:hover {
    opacity: 0.9;
    box-shadow: var(--shadow-glow-md);
  }

  .btn--ghost {
    background: rgba(255,255,255,0.06);
    color: var(--text-primary);
    border: 1px solid var(--border);
  }
  .btn--ghost:hover {
    background: rgba(255,255,255,0.1);
    border-color: var(--phoenix-fire);
    color: var(--phoenix-fire);
  }

  .btn--outline {
    background: transparent;
    color: var(--phoenix-fire);
    border: 1px solid var(--phoenix-fire);
  }
  .btn--outline:hover {
    background: rgba(234, 88, 12, 0.1);
    box-shadow: var(--shadow-glow-sm);
  }

  .btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
  }
</style>
