---
interface Props {
  variant?: 'fire' | 'muted' | 'outline';
  class?:   string;
}

const { variant = 'muted', class: extraClass = '' } = Astro.props;
---

<span class={`badge badge--${variant} ${extraClass}`}>
  <slot />
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 100px;
    letter-spacing: 0.05em;
  }

  .badge--fire {
    background: rgba(234, 88, 12, 0.15);
    color: var(--phoenix-fire);
    border: 1px solid rgba(234, 88, 12, 0.3);
  }

  .badge--muted {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text-secondary);
    border: 1px solid var(--border);
  }

  .badge--outline {
    background: transparent;
    color: var(--phoenix-gold);
    border: 1px solid var(--phoenix-gold);
  }
</style>
