---
const year = new Date().getFullYear();

const links = {
  servicios: [
    { href: '/servicios#web',            label: 'Desarrollo Web' },
    { href: '/servicios#software',       label: 'Software a medida' },
    { href: '/servicios#automatizacion', label: 'Automatizaciones' },
    { href: '/servicios#seo',            label: 'Auditoría SEO' },
  ],
  empresa: [
    { href: '/nosotros',  label: 'Nosotros' },
    { href: '/portfolio', label: 'Portfolio' },
    { href: '/blog',      label: 'Blog' },
    { href: '/contacto',  label: 'Contacto' },
  ],
};
---

<footer>
  <div class="section-container footer-inner">
    <!-- Brand -->
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="Avefenix Software">
        <svg width="28" height="28" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M16 2C16 2 8 8 8 16C8 20.4 11.6 24 16 24C20.4 24 24 20.4 24 16C24 11.6 20.4 8 20.4 8" stroke="url(#grad-f)" stroke-width="2.5" stroke-linecap="round"/>
          <path d="M16 24V30M13 30H19" stroke="url(#grad-f)" stroke-width="2.5" stroke-linecap="round"/>
          <circle cx="16" cy="16" r="3" fill="url(#grad-f)"/>
          <defs>
            <linearGradient id="grad-f" x1="8" y1="2" x2="24" y2="30" gradientUnits="userSpaceOnUse">
              <stop offset="0%" stop-color="#EA580C"/>
              <stop offset="100%" stop-color="#FCD34D"/>
            </linearGradient>
          </defs>
        </svg>
        <span>AVEFENIX SOFTWARE</span>
      </a>
      <p>Transformamos tu negocio con tecnología. Desarrollo web, software a medida, automatizaciones y auditoría SEO.</p>
      <a href="mailto:daferur@gmail.com" class="footer-email">daferur@gmail.com</a>
    </div>

    <!-- Servicios -->
    <div class="footer-col">
      <h4>Servicios</h4>
      <ul role="list">
        {links.servicios.map(({ href, label }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </div>

    <!-- Empresa -->
    <div class="footer-col">
      <h4>Empresa</h4>
      <ul role="list">
        {links.empresa.map(({ href, label }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer-bottom">
    <div class="section-container bottom-inner">
      <p>&copy; {year} Avefenix Software. Todos los derechos reservados.</p>
      <p>Hecho con fuego en España 🇪🇸</p>
    </div>
  </div>
</footer>

<style>
  footer {
    margin-top: 6rem;
    border-top: 1px solid var(--border);
    background: var(--bg-surface);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  @media (min-width: 640px) {
    .footer-inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer-inner {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.08em;
    color: var(--text-primary);
  }

  .footer-brand p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    max-width: 320px;
  }

  .footer-email {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--phoenix-fire);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-email:hover {
    color: var(--phoenix-gold);
  }

  .footer-col h4 {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-col a:hover {
    color: var(--phoenix-fire);
  }

  .footer-bottom {
    border-top: 1px solid var(--border);
  }

  .bottom-inner {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 1.5rem;
    padding-bottom: 1.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  @media (min-width: 640px) {
    .bottom-inner {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>
